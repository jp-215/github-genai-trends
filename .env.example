# Copy to .env (for local runs) or set as a GitHub Actions secret.

# Discord webhook the alert posts to. Create one in your target channel:
# Channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Without it, the detector just prints to stdout.
DISCORD_WEBHOOK_URL=

# Optional: a GitHub token raises the Search API rate limit. In GitHub Actions the
# built-in secrets.GITHUB_TOKEN is passed automatically — no setup needed.
GITHUB_TOKEN=

# Optional overrides:
# GHT_QUERIES="topic:llm;topic:ai-agents;llm token efficient"   # ';'-separated
# GHT_RELEVANCE_TERMS="llm;agent;rag;token;mcp"                  # ';'-separated
# GHT_LABEL="GenAI on GitHub"
# GHT_LOOKBACK_DAYS=30
# GHT_MIN_STARS=20
# GHT_MAX_ITEMS=10
